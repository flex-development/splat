{
  "name": "@flex-development/splat",
  "description": "Universal glob pattern scanning, parsing, and matching",
  "version": "0.0.0",
  "keywords": [
    "ast",
    "browser",
    "esm",
    "glob",
    "glob-matching",
    "glob-pattern",
    "javascript",
    "match",
    "matcher",
    "micromatch",
    "minimatch",
    "node",
    "nodejs",
    "parser",
    "path",
    "pattern",
    "pattern-matching",
    "picomatch",
    "tokenizer",
    "typescript",
    "unist",
    "wildcard",
    "wildcard-matching"
  ],
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/flex-development/splat",
  "repository": "https://github.com/flex-development/splat.git",
  "bugs": "https://github.com/flex-development/splat/issues",
  "author": {
    "name": "Lexus Drumgold",
    "url": "https://github.com/unicornware"
  },
  "publishConfig": {
    "access": "public",
    "diff-dst-prefix": "splat",
    "diff-src-prefix": "splat",
    "directory": "./",
    "executableFiles": [],
    "node-options": null,
    "pack-destination": ".",
    "parseable": true,
    "prefer-dedupe": true,
    "provenance": true,
    "tag-version-prefix": ""
  },
  "type": "module",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "splat": "./src/index.mts",
      "default": "./dist/index.mjs"
    },
    "./ast": {
      "splat": "./src/ast/index.mts",
      "default": "./dist/ast/index.mjs"
    },
    "./package.json": "./package.json",
    "./tokenize": {
      "splat": "./src/tokenize/index.mts",
      "default": "./dist/tokenize/index.mjs"
    }
  },
  "imports": {
    "#ast/content/*": "./src/ast/content/*.mts",
    "#ast/interfaces/*": "./src/ast/interfaces/*.mts",
    "#ast/nodes/*": "./src/ast/nodes/*.mts",
    "#ast/types/*": "./src/ast/types/*.mts",
    "#fixtures/*": "./__fixtures__/*.mts",
    "#tests/*": "./__tests__/*.mts",
    "#tokenize/constructs/*": {
      "splat": "./src/tokenize/constructs/*.mts",
      "default": "./dist/tokenize/constructs/*.mjs"
    },
    "#tokenize/enums/*": {
      "splat": "./src/tokenize/enums/*.mts",
      "default": "./dist/tokenize/enums/*.mjs"
    },
    "#tokenize/interfaces/*": {
      "splat": "./src/tokenize/interfaces/*.mts",
      "default": "./dist/tokenize/interfaces/*.mjs"
    },
    "#tokenize/internal/*": {
      "splat": "./src/tokenize/internal/*.mts",
      "default": "./dist/tokenize/internal/*.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "remarkConfig": {
    "plugins": [
      "@flex-development/remark-preset"
    ]
  },
  "scripts": {
    "build": "yarn clean:build && tsc -p tsconfig.build.json --noEmit false && rollup -c=rollup.config.mts && trash dist/{ast,tokenize}/**/*.{d.mts,mjs} !dist/ast/index.d.mts \"!dist/tokenize/index.{d.mts,mjs}\" && delete-empty dist",
    "check:ci": "yarn dedupe --check && yarn check:format && yarn check:lint && yarn check:spelling && yarn typecheck && yarn check:types && yarn test:cov && attw --pack && yarn check:types:build",
    "check:format": "dprint check --incremental=false",
    "check:lint": "eslint --exit-on-fatal-error --max-warnings 0 .",
    "check:spelling": "cspell lint --color --no-progress --relative $@ \"**\"",
    "check:types": "tsc -p tsconfig.typecheck.json",
    "check:types:build": "tsc -p tsconfig.build.json",
    "check:upgrades": "yarn upgrade-interactive",
    "clean:build": "trash \"./{dist,*.tgz}\" || exit 0",
    "clean:modules": "trash ./.yarn/{cache,*.gz} ./node_modules",
    "clean:pack": "trash \"./*.tgz\"",
    "clean:test": "trash ./coverage && trash __tests__/reports",
    "codecov": "yarn test:cov && yarn test:cov:upload",
    "codecov:validate": "cat .codecov.yml | curl --data-binary @- https://codecov.io/validate",
    "commitlint": "commitlint -V",
    "fix:cg": "yarn fix:format && yarn fix:lint",
    "fix:dedupe": "yarn dedupe --strategy=highest",
    "fix:format": "dprint fmt",
    "fix:lint": "yarn check:lint --cache --fix",
    "postinstall": "[ -f ./.git ] && [ -f ./node_modules/.bin/husky ] && chmod +x .husky/_/* && husky || exit 0",
    "postpack": "toggle-scripts +postinstall",
    "postpublish": "toggle-scripts +prepack",
    "prepack": "toggle-scripts -postinstall && yarn build",
    "prepublishOnly": "toggle-scripts -prepack",
    "release": "bash ./scripts/release.sh",
    "remark": "remark .",
    "test": "yarn clean:build; vitest run",
    "test:cov": "yarn test --coverage",
    "test:cov:reports": "yarn test:cov --merge-reports --mode=reports",
    "test:cov:ui": "yarn test:ui --coverage",
    "test:cov:upload": "./codecov -t $CODECOV_TOKEN -f ./coverage/lcov.info",
    "test:reports": "yarn test --merge-reports --mode=reports",
    "test:ui": "cross-env VITEST_UI=1 vitest --ui",
    "typecheck": "yarn test --typecheck --mode=typecheck",
    "typecheck:ui": "yarn test:ui --typecheck --mode=typecheck"
  },
  "dependencies": {
    "@flex-development/fsm-tokenizer": "1.0.0-alpha.9",
    "@flex-development/unist-util-types": "1.6.1",
    "@types/unist": "3.0.3",
    "devlop": "1.1.0",
    "micromark-util-character": "2.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@commitlint/cli": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@edge-runtime/vm": "5.0.0",
    "@flex-development/commitlint-config": "1.0.1",
    "@flex-development/eslint-config": "1.1.1",
    "@flex-development/export-regex": "2.0.0",
    "@flex-development/grease": "3.0.0-alpha.9",
    "@flex-development/import-regex": "3.0.0",
    "@flex-development/pathe": "4.0.2",
    "@flex-development/remark-preset": "1.0.0",
    "@flex-development/tutils": "6.0.0-alpha.25",
    "@flex-development/unist-util-inspect": "1.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@tsconfig/strictest": "2.0.8",
    "@types/concat-stream": "2.0.3",
    "@types/is-ci": "3.0.4",
    "@types/micromatch": "4.0.10",
    "@types/node-notifier": "8.0.5",
    "@types/rollup": "0.54.0",
    "@types/unist": "3.0.3",
    "@vates/toggle-scripts": "1.0.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "concat-stream": "2.0.0",
    "convert-hrtime": "5.0.0",
    "cross-env": "10.1.0",
    "cspell": "10.0.1",
    "delete-empty": "3.0.0",
    "dprint": "0.54.0",
    "editorconfig": "3.0.2",
    "eslint": "9.39.4",
    "growl": "1.10.5",
    "happy-dom": "20.10.2",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "micromatch": "4.0.8",
    "node-notifier": "10.0.1",
    "pkg-size": "2.4.0",
    "remark": "15.0.1",
    "remark-cli": "12.0.1",
    "rollup": "4.61.1",
    "rollup-plugin-cleanup": "3.2.1",
    "rollup-plugin-dts": "6.4.1",
    "sh-syntax": "0.5.8",
    "trash-cli": "7.2.0",
    "ts-dedent": "2.2.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "unified": "11.0.5",
    "vfile": "6.0.3",
    "vitest": "4.1.8"
  },
  "packageManager": "yarn@4.16.0",
  "sideEffects": false
}
